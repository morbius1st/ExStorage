<Window x:Name="StartWin"
		x:Class="ExStoreTest2026.Windows.ExStorStartWin"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:local="clr-namespace:ExStoreTest2026.Windows"
		xmlns:sys="clr-namespace:System;assembly=mscorlib"
		xmlns:revitLibrary="clr-namespace:RevitLibrary"
		Title="ExStorStartWin"
		Width="800"
		Height="450"
		DataContext="{Binding ElementName=StartWin}"
		mc:Ignorable="d"
		Background="#222222"
		BorderThickness="0"
		BorderBrush="Transparent"
		>
	<Window.Resources>

		<sys:Double x:Key="BtnWidth">110</sys:Double>
		<sys:Double x:Key="BtnHeight">33</sys:Double>
		<sys:Double x:Key="LblHeight">14</sys:Double>
		<sys:Double x:Key="statHeight">20</sys:Double>

		<Style x:Key="BtnStyleBase"
				TargetType="Button"
				>
			<Setter Property="BorderBrush" Value="#EEEEEEEE" />
			<Setter Property="Background" Value="#EEEEEEEE" />
			<Setter Property="Margin" Value="0,2.5,0,2.5" />
			<Setter Property="Height" Value="{StaticResource BtnHeight}" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
		</Style>


		<Style x:Key="BtnStyleTop"
				TargetType="Button"
				BasedOn="{StaticResource BtnStyleBase}"
		>
			<Setter Property="Margin" Value="0,1.5,0,2.5" />
		</Style>

		<Style x:Key="BtnStyleBott"
				TargetType="Button"
				BasedOn="{StaticResource BtnStyleBase}"
		>
			<Setter Property="Margin" Value="0,2.5,0,1.5" />
		</Style>

		<Style x:Key="BtnSolo"
				TargetType="Button"
				BasedOn="{StaticResource BtnStyleBase}"
		>
			<Setter Property="Margin" Value="0,1.5,0,1.5" />
		</Style>

		<Style x:Key="Rect"
				TargetType="Rectangle"
		>
			<Setter Property="Margin" Value="-2,0.5,-2,0.5" />
			<Setter Property="Height" Value="1" />
		</Style>

		<Style x:Key="LblTextBlock"
				TargetType="TextBlock"
		>
			<Setter Property="Foreground" Value="Red" />
			<Setter Property="Margin" Value="0,-2.5,0,0" />
			<Setter Property="Padding" Value="0" />
		</Style>

		<Style x:Key="Label"
				TargetType="Label"
		>
			<Setter Property="Height" Value="{StaticResource LblHeight}" />
			<Setter Property="Margin" Value="0,1.5,0,2.5" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="HorizontalContentAlignment" Value="Center" />
			<Setter Property="Foreground" Value="Red" />
			<Setter Property="Background" Value="White" />
		</Style>


	</Window.Resources>
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="auto" />
			<ColumnDefinition Width="120" />
			<ColumnDefinition Width="120" />
		</Grid.ColumnDefinitions>

		<Grid.RowDefinitions>
			<RowDefinition Height="80" />
			<RowDefinition Height="*" />
			<RowDefinition Height="40" />
		</Grid.RowDefinitions>

		<StackPanel
				Grid.Column="1"
				Grid.Row="2"
				Grid.ColumnSpan="3"
				Margin="0,0,5,5"
				>
			<Button Name="BtnExit"
					Content="Exit"
					Margin="0,5,0,0"
					Width="{StaticResource BtnWidth}"
					HorizontalAlignment="Right"
					Style="{StaticResource BtnStyleBase}"
					Click="BtnExit_OnClick"
					/>

		</StackPanel>

		<TextBox
				Grid.Column="0"
				Grid.Row="1"
				Margin="3"
				FontFamily="Consolas"
				Background="#333333"
				Foreground="White"
				VerticalScrollBarVisibility="Visible"
				HorizontalScrollBarVisibility="Visible"
				Text="{Binding ElementName=StartWin,
											 Path=Message}"
				BorderBrush="#333333"
				/>

		<StackPanel
				Grid.Column="0"
				Grid.Row="0"
				Orientation="Horizontal"
				Margin="3"
				>

			<StackPanel
					Width="190"
					Orientation="Vertical"
					Margin="0"
			>

				<DockPanel
						Margin="0"
						VerticalAlignment="Top"
						HorizontalAlignment="Stretch"
						Height="{StaticResource statHeight}"

				>
				<Label
						Padding="3,0,5,0"
						Margin="0"
						Content="Status 1"
						Background="Black"
						Foreground="White"
						/>

				<Label
						HorizontalContentAlignment="Stretch"
						HorizontalAlignment="Stretch"
						Padding="5,0,5,0"
						Margin="0"
						Content="Status Value"
						Background="#333333"
						Foreground="White"
				/>

				</DockPanel>


			</StackPanel>


		</StackPanel>

		<DockPanel 
				Grid.Column="3"
				Grid.Row="0"
				Grid.RowSpan="2"
				Margin="0,0,3,0"
				>
			<StackPanel
					Orientation="Vertical"
					>
	
				<Rectangle
						Fill="Red"
						Style="{StaticResource Rect}"
				/>

				<Label Style="{StaticResource Label}">
					<Label.Content>
						<TextBlock
								Text="Test 1"
								Style="{StaticResource LblTextBlock}"
						/>
					</Label.Content>
				</Label>


			<Button Name="BtnTest1"
					Content="Test 1"
					Style="{StaticResource BtnStyleBott}"
			/>


				</StackPanel>
		</DockPanel>



	</Grid>
</Window>
