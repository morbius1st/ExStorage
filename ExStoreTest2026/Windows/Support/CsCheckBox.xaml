		<ResourceDictionary Source="pack://Application:,,,/ExStoreTest2026;component/Windows/Support/MasterColorList.xaml" />
		<ResourceDictionary Source="pack://Application:,,,/ExStoreTest2026;component/Windows/Support/CyberStudioSkin.xaml" />
	</ResourceDictionary.MergedDictionaries>

