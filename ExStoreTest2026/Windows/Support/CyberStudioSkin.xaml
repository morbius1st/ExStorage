	<!--#region > styles-->

	<!--#region > styles - borders-->

	<Style x:Key="BdrBasic"
			TargetType="Border"
			>
		<Setter Property="Background" Value="Gray"/>
		<Setter Property="BorderBrush" Value="White"/>
		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="CornerRadius" Value="{StaticResource CornerRadius.Std}"/>
		<Setter Property="Padding" Value="0"/>
		<Setter Property="Margin" Value="0"/>
	</Style>

	<Style x:Key="BdrHeader"
			TargetType="Border"
			BasedOn="{StaticResource BdrBasic}"
			>
		<Setter Property="Background" Value="{DynamicResource Header.Bg.IsSel.B}"/>
		<Setter Property="VerticalAlignment" Value="Top">
		</Setter>
	</Style>

	<!--#endregion-->

	<!--#region > styles - scrollviewer-->

	<Style x:Key="ScrollViewerStyle"
			TargetType="ScrollViewer"
			>
		<Setter Property="Template" Value="{DynamicResource CsScrollViewerCt}"/>
		<Setter Property="cs:CsScrollBarAp.ScrollBarWidth" Value="15"/>
		<Setter Property="cs:CsScrollBarAp.RepeatButtonLength" Value="15"/>
		<Setter Property="cs:CsScrollBarAp.RepeatButtonIconLength" Value="12"/>
		<Setter Property="cs:CsScrollBarAp.RepeatButtonIconGirth" Value="8"/>

	</Style>


	<!--#endregion-->


	<!--#region > styles - textbox-->

	<Style x:Key="TbxBasic"
			TargetType="{x:Type TextBox}"
			>
		<Setter Property="Margin" Value="0,0,0,0"/>
		<Setter Property="Padding" Value="0,0,0,2"/>
		<Setter Property="HorizontalAlignment" Value="Left"/>
		<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="Foreground" Value="White"/>

	</Style>

	<Style x:Key="TbxEditing"
			TargetType="{x:Type TextBox}"
			BasedOn="{StaticResource TbxBasic}"
			>
		<Setter Property="MaxLines" Value="1"/>
		<Setter Property="Padding" Value="5,0,5,2"/>
		<Setter Property="HorizontalAlignment" Value="Stretch"/>
		<Setter Property="Background" Value="{StaticResource Bg.CanEdit}"/>
		<Setter Property="BorderThickness" Value="0"/>

	</Style>

	<Style x:Key="TbxEditingFolder"
			TargetType="{x:Type TextBox}"
			BasedOn="{StaticResource TbxEditing}"
			>
	</Style>


	<Style x:Key="TbxStatus"
			TargetType="TextBox"
			BasedOn="{StaticResource TbxBasic}"
			>

		<Setter Property="Background" Value="{StaticResource Bg.CanEdit}"/>
		<Setter Property="VerticalAlignment" Value="Stretch"/>
		<Setter Property="HorizontalAlignment" Value="Stretch"/>
		<Setter Property="HorizontalScrollBarVisibility" Value="Visible"/>
		<Setter Property="VerticalScrollBarVisibility" Value="Visible"/>
		<Setter Property="FontFamily" Value="Consolas"/>
		<Setter Property="FontSize" Value="14"/>
		<Style.Resources>
			<Style
					TargetType="{x:Type ScrollViewer}"
					BasedOn="{StaticResource ScrollViewerStyle}"
					/>
		</Style.Resources>
	</Style>

	<!--#endregion-->

	<!--#region > styles - textblock-->

	<Style x:Key="TblkBasic"
			TargetType="TextBlock"
			>
		<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="Foreground" Value="White"/>
		<Setter Property="Margin" Value="0"/>
		<Setter Property="Padding" Value="0"/>
		<Setter Property="FontSize" Value="{StaticResource FontSize.Normal}"/>
	</Style>


	<Style x:Key="TblkHeaderBase"
			TargetType="TextBlock"
			BasedOn="{StaticResource TblkBasic}"
			>
		<Setter Property="Padding" Value="5,1,0,4"/>
		<Setter Property="Margin" Value="0,-2,0,0"/>
	</Style>


	<Style x:Key="TblkHeaderPrime"
			TargetType="TextBlock"
			BasedOn="{StaticResource TblkHeaderBase}"
			>
		<Setter Property="FontSize" Value="{StaticResource FontSize.Large}"/>
		<Setter Property="VerticalAlignment" Value="Bottom"/>
	</Style>

	<Style x:Key="TblkHeaderSecond"
			TargetType="TextBlock"
			BasedOn="{StaticResource TblkHeaderBase}"
			>
		<Setter Property="FontSize" Value="{StaticResource FontSize.Large}"/>
		<Setter Property="VerticalAlignment" Value="Bottom"/>
	</Style>

