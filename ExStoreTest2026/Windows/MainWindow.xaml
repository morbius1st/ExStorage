					>
				<Setter Property="BorderBrush" Value="#EEEEEEEE" />
				<Setter Property="Background" Value="#EEEEEEEE" />
				<Setter Property="Margin" Value="0,2.5,0,2.5" />
				<Setter Property="Height" Value="{StaticResource BtnHeight}" />
				<Setter Property="Padding" Value="0" />
				<Setter Property="HorizontalAlignment" Value="Stretch" />
			</Style>

			<Style x:Key="BtnStyleTop"
					TargetType="Button"
					BasedOn="{StaticResource BtnStyleBase}"
					>
				<Setter Property="Margin" Value="0,1.5,0,2.5" />
			</Style>

			<Style x:Key="BtnStyleBott"
					TargetType="Button"
					BasedOn="{StaticResource BtnStyleBase}"
					>
				<Setter Property="Margin" Value="0,2.5,0,1.5" />
			</Style>

			<Style x:Key="BtnEditNameWithIcon"
					TargetType="Button"
					BasedOn="{StaticResource Btn.Std}"
					>
				<Setter Property="Width" Value="20" />
				<Setter Property="Height" Value="20" />
				<Setter Property="Padding" Value="2" />
				<Setter Property="Background" Value="Transparent" />
				<Setter Property="BorderBrush" Value="Transparent" />
			</Style>


			<!--  rect styles  -->

			<Style x:Key="Rect"
					TargetType="Rectangle"
					>
				<Setter Property="Margin" Value="-2,0.5,-2,0.5" />
