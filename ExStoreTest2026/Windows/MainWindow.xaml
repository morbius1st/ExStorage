<Window Name="MainWin"
		x:Class="ExStoreTest2026.Windows.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:local="clr-namespace:ExStoreTest2026.Windows"
		xmlns:sys="clr-namespace:System;assembly=mscorlib"
		xmlns:revitLibrary="clr-namespace:RevitLibrary"
		Title="MainWindow"
		Width="1600"
		Height="1050"
		DataContext="{Binding ElementName=MainWin}"
		mc:Ignorable="d"
		Background="#222222"
		BorderThickness="0"
		BorderBrush="Transparent"
		Closing="MainWin_Closing"
		Activated="MainWin_Activated"
		Loaded="MainWindow_OnLoaded" 
		>
		<!-- SourceInitialized="MainWin_SourceInitialized" -->
	<Window.Resources>

		<sys:Double x:Key="BtnWidth">140</sys:Double>
		<sys:Double x:Key="BtnHeight">33</sys:Double>

		<sys:Double x:Key="LblValueNumber">58</sys:Double>

		<sys:Double x:Key="LblHeight">14</sys:Double>

		<GridLength x:Key="griRowHeight">22</GridLength>

		<Style x:Key="Lbl"
				TargetType="{x:Type Label}"
				>
			<Setter Property="FontSize" Value="11" />
		</Style>

		<Style x:Key="BtnStyleBase"
				TargetType="Button"
				>
			<Setter Property="BorderBrush" Value="#EEEEEEEE" />
			<Setter Property="Background" Value="#EEEEEEEE" />
			<Setter Property="Margin" Value="0,2.5,0,2.5" />
			<Setter Property="Height" Value="{StaticResource BtnHeight}" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
		</Style>

		<Style x:Key="BtnStyleTop"
				TargetType="Button"
				BasedOn="{StaticResource BtnStyleBase}"
				>
			<Setter Property="Margin" Value="0,1.5,0,2.5" />
		</Style>

		<Style x:Key="BtnStyleBott"
				TargetType="Button"
				BasedOn="{StaticResource BtnStyleBase}"
				>
			<Setter Property="Margin" Value="0,2.5,0,1.5" />
		</Style>

		<Style x:Key="BtnSolo"
				TargetType="Button"
				BasedOn="{StaticResource BtnStyleBase}"
				>
			<Setter Property="Margin" Value="0,1.5,0,1.5" />
		</Style>

		<Style x:Key="Rect"
				TargetType="Rectangle"
				>
			<Setter Property="Margin" Value="-2,0.5,-2,0.5" />
			<Setter Property="Height" Value="1" />
		</Style>

		<Style x:Key="LblTextBlock"
				TargetType="TextBlock"
				>
			<Setter Property="Foreground" Value="Red" />
			<Setter Property="Margin" Value="0,-2.5,0,0" />
			<Setter Property="Padding" Value="0" />
		</Style>

		<Style x:Key="Label"
				TargetType="Label"
				>
			<Setter Property="Height" Value="{StaticResource LblHeight}" />
			<Setter Property="Margin" Value="0,1.5,0,2.5" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="HorizontalContentAlignment" Value="Center" />
			<Setter Property="Foreground" Value="Red" />
			<Setter Property="Background" Value="White" />
		</Style>

		<Style x:Key="LblTitle"
				TargetType="Label"
				BasedOn="{StaticResource Lbl}"
				>
			<Setter Property="Background" Value="#111111" />
			<Setter Property="Foreground" Value="DarkGray" />
			<Setter Property="Margin" Value="0,1.0,0,0" />
			<Setter Property="Padding" Value="3,0,0,4" />
			<Setter Property="VerticalContentAlignment" Value="Center" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="VerticalAlignment" Value="Stretch" />
		</Style>

		<Style x:Key="LblValue"
				TargetType="Label"
				BasedOn="{StaticResource LblTitle}"
				>
			<Setter Property="Margin" Value="2,1.0,0,0" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="Background" Value="#333333" />
			<!-- <Setter Property="ToolTip" Value="{Binding Content}"/> -->
		</Style>

	</Window.Resources>

	<Grid Margin="5">

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="Auto" />
		</Grid.ColumnDefinitions>

		<Grid.RowDefinitions>
			<RowDefinition Height="190" />
			<RowDefinition Height="*" />
			<RowDefinition Height="40" />
		</Grid.RowDefinitions>

		<Grid
				Height="auto"
				VerticalAlignment="Top"
				>
			<Grid.Resources>

			</Grid.Resources>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="130" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="130" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="130" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<Grid.RowDefinitions>
				<RowDefinition Height="{StaticResource griRowHeight}" />
				<RowDefinition Height="{StaticResource griRowHeight}" />
				<RowDefinition Height="{StaticResource griRowHeight}" />
				<RowDefinition Height="{StaticResource griRowHeight}" />
				<RowDefinition Height="{StaticResource griRowHeight}" />
				<RowDefinition Height="{StaticResource griRowHeight}" />
				<RowDefinition Height="{StaticResource griRowHeight}" />
				<RowDefinition Height="{StaticResource griRowHeight}" />
			</Grid.RowDefinitions>


			<Label
					Content="Object Id"
					Grid.Column="0"
					Grid.Row="0"
					Style="{StaticResource LblTitle}"
			/>

			<Label
					Content="{Binding Path=ObjId, FallbackValue='void',
														TargetNullValue='does not exist'}"
					Grid.Column="1"
					Grid.Row="0"
					Style="{StaticResource LblValue}"
			/>


			<Label
					Content="Doc File Name"
					Grid.Column="0"
					Grid.Row="1"
					Style="{StaticResource LblTitle}"
					/>

			<Label
					Content="{Binding Path=(revitLibrary:R.FileName), Mode=OneWay,
														TargetNullValue='does not exist'}"
					Grid.Column="1"
					Grid.Row="1"
					Style="{StaticResource LblValue}"
					/>
			<!-- Content="{Binding Source={x:Static revitLibrary:R.FileName}, Mode=OneWay, -->
			<!-- TargetNullValue='does not exist'}" -->

			<Label
					Content="Open Model Count"
					Grid.Column="0"
					Grid.Row="2"
					Margin="0"
					Style="{StaticResource LblTitle}"
					/>

			<Label
					Content="{Binding Path=Mui.OpenModelCount,
														FallbackValue='undetermined',
														Mode=OneWay}"
					Grid.Column="1"
					Grid.Row="2"
					Style="{StaticResource LblValue}"
					/>



			<Label
					Content="WBK Schema Status"
					Grid.Column="0"
					Grid.Row="4"
					Style="{StaticResource LblTitle}"
					/>

			<DockPanel
					Grid.Column="1"
					Grid.Row="4"
					Margin="0"
					HorizontalAlignment="Stretch"
					VerticalAlignment="Stretch"
					>

				<Label
