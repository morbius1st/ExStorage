			<!--#region > tab control-->

			<Style x:Key="TbBdrHdrInner"
					TargetType="Border"
					>
				<Setter Property="Margin" Value="0,0,0,-1" />
				<Setter Property="Padding" Value="10,2,10,1" />
				<Setter Property="BorderThickness" Value="0,0,0,1" />
				<Setter Property="BorderBrush" Value="Red" />
				<Style.Triggers>
					<DataTrigger Value="True" Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type TabItem}}, Path=IsSelected}">
						<Setter Property="BorderBrush" Value="DimGray" />
					</DataTrigger>
				</Style.Triggers>
			</Style>

			<Style x:Key="TbBdrHdrOuter"
					TargetType="Border"
					>
				<Setter Property="Margin" Value="0,2,0,0" />
				<Setter Property="Padding" Value="0" />
				<Setter Property="BorderThickness" Value="1,1,1,0" />
				<Setter Property="CornerRadius" Value="3,3,0,0" />
				<Setter Property="BorderBrush" Value="Red" />
				<Setter Property="Background" Value="DimGray">
				</Setter>
				<Style.Triggers>
					<DataTrigger Value="false" Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type TabItem}}, Path=IsSelected}">
						<Setter Property="BorderBrush" Value="DarkGray" />
						<Setter Property="Background" Value="#222222" />
						<Setter Property="BorderThickness" Value=".5,.5,.5,0" />
					</DataTrigger>
				</Style.Triggers>
			</Style>

			<Style x:Key="TbHdrTblk"
					TargetType="TextBlock"
					>
				<Setter Property="Foreground" Value="DarkGray" />
				<Style.Triggers>
					<DataTrigger Value="True" Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type TabItem}}, Path=IsSelected}">
						<Setter Property="Foreground" Value="White">
						</Setter>
					</DataTrigger>
				</Style.Triggers>
			</Style>

			<SolidColorBrush x:Key="TabItem.Selected.Background" Color="#FFFFFF" />
			<SolidColorBrush x:Key="TabItem.Selected.Border" Color="#ACACAC" />

			<Style x:Key="TabControlStyle1"
					TargetType="{x:Type TabControl}"
					>
				<Setter Property="Padding" Value="0" />
				<Setter Property="HorizontalContentAlignment" Value="Center" />
				<Setter Property="VerticalContentAlignment" Value="Center" />
				<Setter Property="Background" Value="{StaticResource TabItem.Selected.Background}" />
				<Setter Property="BorderBrush" Value="{StaticResource TabItem.Selected.Border}" />
				<Setter Property="BorderThickness" Value="1" />
				<Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type TabControl}">
							<Grid x:Name="templateRoot"
									ClipToBounds="true"
									SnapsToDevicePixels="true"
									KeyboardNavigation.TabNavigation="Local"
									>
								<Grid.ColumnDefinitions>
									<ColumnDefinition x:Name="ColumnDefinition0" />
									<ColumnDefinition x:Name="ColumnDefinition1"
											Width="0"
											/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition x:Name="RowDefinition0"
											Height="Auto"
											/>
									<RowDefinition x:Name="RowDefinition1"
											Height="*"
											/>
								</Grid.RowDefinitions>
								<TabPanel x:Name="headerPanel"
										Grid.Row="0"
										Grid.Column="0"
										Margin="0,0,0,0"
										Panel.ZIndex="1"
										Background="Transparent"
										IsItemsHost="true"
										KeyboardNavigation.TabIndex="1"
										/>
								<Border x:Name="contentPanel"
										Grid.Row="1"
										Grid.Column="0"
										Background="{TemplateBinding Background}"
										BorderThickness="{TemplateBinding BorderThickness}"
										BorderBrush="{TemplateBinding BorderBrush}"
