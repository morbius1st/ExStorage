			</Style>

			<!--  label styles  -->

			<Style x:Key="LblCtrlSample"
					TargetType="Label"
					>
				<Setter Property="Margin" Value="0" />
				<Setter Property="Padding" Value="0" />
				<Setter Property="FontSize" Value="4" />
				<Setter Property="Foreground" Value="White" />
				<Setter Property="HorizontalAlignment" Value="Center" />
				<Setter Property="VerticalAlignment" Value="Bottom" />

			</Style>

			<Style x:Key="Lbl"
					TargetType="{x:Type Label}"
					>
				<Setter Property="FontSize" Value="11" />
			</Style>

			<Style x:Key="LblTextBlock"
					TargetType="TextBlock"
					>
				<Setter Property="Foreground" Value="Red" />
				<Setter Property="Margin" Value="0,-2.5,0,0" />
				<Setter Property="Padding" Value="0" />
			</Style>

			<Style x:Key="Label"
					TargetType="Label"
					>
				<Setter Property="Height" Value="{StaticResource LblHeight}" />
				<Setter Property="Margin" Value="0,1.5,0,2.5" />
				<Setter Property="Padding" Value="0" />
				<Setter Property="HorizontalAlignment" Value="Stretch" />
				<Setter Property="HorizontalContentAlignment" Value="Center" />
				<Setter Property="Foreground" Value="Red" />
				<Setter Property="Background" Value="White" />
			</Style>

			<Style x:Key="LblTitle"
					TargetType="Label"
					BasedOn="{StaticResource Lbl}"
					>
				<Setter Property="Background" Value="#111111" />
				<Setter Property="Foreground" Value="DarkGray" />
				<Setter Property="Margin" Value="0,1.0,0,0" />
				<Setter Property="Padding" Value="3,0,0,4" />
				<Setter Property="VerticalContentAlignment" Value="Center" />
				<Setter Property="HorizontalAlignment" Value="Stretch" />
				<Setter Property="VerticalAlignment" Value="Stretch" />
			</Style>

			<Style x:Key="LblValue"
					TargetType="Label"
					BasedOn="{StaticResource LblTitle}"
					>
				<Setter Property="Margin" Value="2,1.0,0,0" />
				<Setter Property="Foreground" Value="White" />
				<Setter Property="Background" Value="#333333" />
				<!-- <Setter Property="ToolTip" Value="{Binding Content}"/> -->
			</Style>

			<!--  content panel styles  -->

			<Style x:Key="LblContent"
					TargetType="Control"
					>
				<Setter Property="MinHeight" Value="16" />
				<Setter Property="FontSize" Value="14" />
				<Setter Property="VerticalAlignment" Value="Center" />

				<Setter Property="Margin" Value="0,0,5,0" />
				<Setter Property="Padding" Value="5,0,5,2" />
				<Setter Property="Foreground" Value="White" />
			</Style>

			<Style x:Key="LblContentStd"
					TargetType="Label"
					BasedOn="{StaticResource LblContent}"
					>
				<Setter Property="Background" Value="Black" />
				<Setter Property="HorizontalAlignment" Value="Left" />
			</Style>

			<Style x:Key="LblContentSecurity"
					TargetType="Label"
					BasedOn="{StaticResource LblContentStd}"
					>
				<Setter Property="Width" Value="150" />
				<Setter Property="BorderBrush" Value="Red" />
				<Setter Property="BorderThickness" Value="1,0,0,0" />
			</Style>

			<Style x:Key="LblContentTitle"
					TargetType="Label"
					BasedOn="{StaticResource LblContentSecurity}"
					>
				<Setter Property="Width" Value="104" />
			</Style>

