				<Setter Property="ContentTemplate">
					<Setter.Value>
						<DataTemplate>
							<ContentControl>
								<ContentControl.Content>
									<Path
											DataContext="{Binding Path=DataContext,
																						RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
											Stretch="UniformToFill"
											Focusable="False"
