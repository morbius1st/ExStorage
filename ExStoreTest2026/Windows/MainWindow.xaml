									>
								<Binding
										ElementName="MainWin"
										Path="Mui.UseSecLvl"
										/>
								<Binding
										Path="Field.FieldEditLevel"
										FallbackValue="{x:Static exSys:FieldEditLevel.FEL_UNASSIGNED}"
										/>
							</MultiBinding>
						</DataTrigger.Binding>
					</DataTrigger>
				</Style.Triggers>
				<Style.Resources>

				</Style.Resources>
