															FallbackValue='1'}"
						Width="{StaticResource LblValueNumber}"
						HorizontalAlignment="Left"
						HorizontalContentAlignment="Center"
						Style="{StaticResource LblValue}"
						/>

				<Label
						Content="{Binding Path=Mui.WbkScResDesc,
															FallbackValue='unassigned',
															Mode=OneWay}"
