			</DockPanel>



			<Label
					Content="WBK Got Schema"
					Grid.Column="2"
					Grid.Row="4"
					Margin="0"
					Style="{StaticResource LblTitle}"
					/>

			<Label
					Content="{Binding Path=Mui.WorkBookSchemaStatusDesc,
														FallbackValue='undetermined',
														Mode=OneWay}"
