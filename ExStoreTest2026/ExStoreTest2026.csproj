    <Compile Include="..\..\LibraryRevit\LibraryRevit\RevitLibrary.cs" Link=".Linked\RevitLibrary.cs" />
  </ItemGroup>

  <ItemGroup>
    <Content Include=".Notes\OperationNotes.txt" />
